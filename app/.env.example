# Feedback API endpoint (Lambda + API Gateway)
NEXT_PUBLIC_FEEDBACK_API=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/feedback

# hCaptcha site key (get from https://www.hcaptcha.com/)
# For development, use test key: 10000000-ffff-ffff-ffff-000000000001
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key
